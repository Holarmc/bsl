# Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration (if needed for contact forms)
# NEXT_PUBLIC_API_URL=https://api.example.com

# Email Service (for contact form submissions)
# SENDGRID_API_KEY=your_sendgrid_api_key
# CONTACT_EMAIL=info@bsl.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Form Submission (if using a form backend)
# NEXT_PUBLIC_FORM_ACTION=https://formspree.io/f/your_form_id

# Database (if adding dynamic content later)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Authentication (if adding user authentication)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_secret_key_here
